<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.PalabraDelDia" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#111318</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.PalabraDelDia.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#111318</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.PalabraDelDia</item>
    </style>

</resources>
