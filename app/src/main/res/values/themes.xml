<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. Compose renders all colours; this just sets
         the window background and status bar to avoid a flash on launch. -->
    <style name="Theme.PalabraDelDia" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash screen theme — shown by the OS before Activity.onCreate() -->
    <style name="Theme.PalabraDelDia.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.PalabraDelDia</item>
    </style>

</resources>
